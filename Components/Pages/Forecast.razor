@page "/forecast"
@using System.Text.RegularExpressions
@using System.ComponentModel.DataAnnotations
@using Financial_ForeCast.Models
@using Financial_ForeCast.Services
@inject DbServiceProvider _dbProvider

<MudContainer Class="mt-16">
    <MudGrid Class="mt-8">
        <MudItem xs="12" sm="12" md="6">
            <MudCard Elevation="25" Class="rounded-lg pb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h5" Align="Align.Center">Forecast Settings</MudText>
                        <MudSelect @bind-Value="roadMapId" Label="RoadMaps">
                            @foreach (var roadM in roadMaps)
                            {
                                <MudSelectItem Value="roadM.Id">@roadM.RoadMapName</MudSelectItem>
                            }
                        </MudSelect>
                    </CardHeaderContent>
                </MudCardHeader>

                <MudCardContent>
                    <MudNumericField @bind-Value="@totalMonthsDisplay" Label="Months" Variant="Variant.Outlined" Adornment="Adornment.End" AdornmentColor="Color.Info" HideSpinButtons="true" />
                    <MudNumericField @bind-Value="@totalYearsDisplay" Label="Years" Variant="Variant.Outlined" Adornment="Adornment.End" AdornmentColor="Color.Info" HideSpinButtons="true" />
                    <MudList T="string" @bind-SelectedValues="SelectedValues" SelectionMode="SelectionMode.MultiSelection" Color="Color.Tertiary" Variant="Variant.Text" hidden="@notUseingStartingCashStack">

                        <MudListItem Text="CashStacks">
                            <NestedList>
                                @foreach (Accnts accnts in Accnts)
                                {
                                    string displayName = accnts.AccountName +": "+ accnts.Amount.ToString();
                                    <MudListItem Text="@displayName" Value="@accnts.Id.ToString()" />
                                }
                            </NestedList>
                        </MudListItem>
                    </MudList>
                    <MudSwitch @bind-Value="@notUseingStartingCashStack" Color="Color.Info">No Starting Cash Stack</MudSwitch>
                </MudCardContent>

                <MudCardActions Class="d-flex justify-center">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Style="width:50%;" OnClick="@Calculate">Calculate</MudButton>
                </MudCardActions>
            </MudCard>

            <MudCard Elevation="25" Class="rounded-lg pb-4 mt-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h5" Align="Align.Center">Saved Forecasts</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    @if (savedForecastNames.Count > 0)
                    {
                        <MudSelect T="string" Label="Load a saved forecast" @bind-Value="selectedSavedForecastName" Variant="Variant.Outlined">
                            @foreach (var name in savedForecastNames)
                            {
                                <MudSelectItem Value="@name">@name</MudSelectItem>
                            }
                        </MudSelect>
                        <MudButtonGroup Class="mt-2" OverrideStyles="false">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@LoadSavedForecast" Disabled="@(string.IsNullOrWhiteSpace(selectedSavedForecastName))">Load</MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="@DeleteSavedForecast" Disabled="@(string.IsNullOrWhiteSpace(selectedSavedForecastName))">Delete</MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@NewForecast">New Forecast</MudButton>
                        </MudButtonGroup>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Align="Align.Center">No saved forecasts yet.</MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="12" md="6" Style="height: 25vh">
            <MudCard Elevation="25" Class="rounded-lg pb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h5" Align="Align.Center">Forecast</MudText>
                    </CardHeaderContent>
                </MudCardHeader>

                <MudCardContent>
                    <MudTable Items="@GetCurrentPageForecasts()" RowsPerPage="12" Hover="true" Breakpoint="Breakpoint.None" LoadingProgressColor="Color.Info" Height="25vh" FixedHeader="true">
                        <HeaderContent>
                            <MudTh>Month</MudTh>
                            <MudTh>Year</MudTh>
                            <MudTh>Savings</MudTh>
                            <MudTh>Extra Income</MudTh>
                            <MudTh>Recurring</MudTh>
                            <MudTh>Total</MudTh>
                            <MudTh>Cash Stack</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Month">@context.Month</MudTd>
                            <MudTd DataLabel="Year">@context.Year</MudTd>
                            <MudTd DataLabel="Savings">@String.Format("{0:0.00}", context.Income)</MudTd>
                            <MudTd DataLabel="Extra Income">
                                <MudNumericField T="double" Value="@context.ExtraIncome" ValueChanged="@(val => OnExtraIncomeChanged(context, val))" Variant="Variant.Text" HideSpinButtons="true" Style="max-width:100px;" />
                            </MudTd>
                            <MudTd DataLabel="Recurring">
                                <MudSwitch T="bool" Value="@context.RecurringExtraIncome" ValueChanged="@(val => OnRecurringChanged(context, val))" Color="Color.Info" />
                            </MudTd>
                            <MudTd DataLabel="Total">@String.Format("{0:0.00}", context.Total)</MudTd>
                            <MudTd DataLabel="Cash Stack">@String.Format("{0:0.00}", context.cashStack)</MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudButton OnClick="PreviousPage" Disabled="@prevPageActive">Previous</MudButton>
                            <MudButton OnClick="NextPage" Disabled="@nextPageActive">Next</MudButton>
                        </PagerContent>
                    </MudTable>
                </MudCardContent>

                <MudButton>
                    <MudTextField T="string" Value="@forcastName" ValueChanged="HandleForecastNameChanged" Label="Forecast Name" Variant="Variant.Outlined" Adornment="Adornment.End" AdornmentColor="Color.Info" Immediate="true" />

                    <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Save" IconColor="Color.Secondary" Size="Size.Large" OnClick="@SaveForecasts" Disabled="@isSaveDisabled">Save</MudButton>
                </MudButton>

            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private IDbService _dbService => _dbProvider.Current;
    private MudTable<Forecasts> _table;
    public IEnumerable<Accnts> Accnts = new List<Accnts>();
    public IEnumerable<RoadMaps> roadMaps = new List<RoadMaps>();
    public List<Forecasts> forecasts = new List<Forecasts>();
    public IReadOnlyCollection<string> SelectedValues;
    int roadMapId;
    public bool notUseingStartingCashStack = false;
    public double startingCashStack;
    public double savingsPerMonth;
    public string totalYearsDisplay { get; set; }
    public string totalMonthsDisplay { get; set; }
    public string forcastName = "";
    public int totalYears;
    public int totalMonths;
    public bool isSaveDisabled = true;

    private Dictionary<int, List<Forecasts>> forecastsByYear;
    private int currentPage = 0;
    private int totalPages = 0;
    private bool prevPageActive = true;
    private bool nextPageActive = true;

    private List<string> savedForecastNames = new List<string>();
    private string selectedSavedForecastName;
    private bool isLoadedForecast = false;

    protected override async Task OnInitializedAsync()
    {
        await updateScreenList();
        GroupForecastsByYear();
    }

    private async Task updateScreenList()
    {
        Accnts = await Task.Run(() => _dbService.GetAccounts());
        roadMaps = await Task.Run(() => _dbService.GetRoadMaps());
        savedForecastNames = await Task.Run(() => _dbService.GetSavedForecastNames());
        if (roadMaps.Any())
        {
            roadMapId = roadMaps.First().Id;
        }
    }

    // Forecast Pagination Logic
    private void CheckIfButtonsActive()
    {
        prevPageActive = currentPage == 0;
        nextPageActive = currentPage == totalPages - 1;
    }

    private void NextPage()
    {
        if (currentPage < totalPages - 1)
        {
            currentPage++;
        }
        CheckIfButtonsActive();
    }

    private void PreviousPage()
    {
        if (currentPage > 0)
        {
            currentPage--;
        }
        CheckIfButtonsActive();
    }

    private void PageChanged(int i)
    {
        _table.NavigateTo(i - 1);
        CheckIfButtonsActive();
    }

    private List<Forecasts> GetCurrentPageForecasts()
    {
        if (forecastsByYear != null && forecastsByYear.Count > 0)
        {
            var year = forecastsByYear.Keys.ElementAt(currentPage);
            return forecastsByYear[year];
        }
        return new List<Forecasts>();
    }
    // End of Forecast Pagination Logic

    // Extra Income Editing
    private void OnExtraIncomeChanged(Forecasts row, double newValue)
    {
        row.ExtraIncome = newValue;

        if (row.RecurringExtraIncome)
        {
            ApplyRecurringExtraIncome(row);
        }

        RecalculateTotals();
        GroupForecastsByYear();
    }

    private void OnRecurringChanged(Forecasts row, bool newValue)
    {
        row.RecurringExtraIncome = newValue;

        if (newValue)
        {
            ApplyRecurringExtraIncome(row);
        }
        else
        {
            RemoveRecurringExtraIncome(row);
        }

        RecalculateTotals();
        GroupForecastsByYear();
    }

    private void ApplyRecurringExtraIncome(Forecasts sourceRow)
    {
        int sourceIndex = forecasts.IndexOf(sourceRow);
        for (int i = sourceIndex + 1; i < forecasts.Count; i++)
        {
            if (forecasts[i].Month == sourceRow.Month)
            {
                forecasts[i].ExtraIncome = sourceRow.ExtraIncome;
                forecasts[i].RecurringExtraIncome = true;
            }
        }
    }

    private void RemoveRecurringExtraIncome(Forecasts sourceRow)
    {
        int sourceIndex = forecasts.IndexOf(sourceRow);
        for (int i = sourceIndex + 1; i < forecasts.Count; i++)
        {
            if (forecasts[i].Month == sourceRow.Month && forecasts[i].RecurringExtraIncome)
            {
                forecasts[i].ExtraIncome = 0;
                forecasts[i].RecurringExtraIncome = false;
            }
        }
    }

    private void RecalculateTotals()
    {
        double runningCash = 0;
        if (forecasts.Count > 0)
        {
            runningCash = 0;
        }

        for (int i = 0; i < forecasts.Count; i++)
        {
            var f = forecasts[i];
            f.Total = f.Income + f.ExtraIncome;
            runningCash += f.Total;
            f.cashStack = runningCash;
        }
    }
    // End of Extra Income Editing

    // Forecast Manipulation
    private void GroupForecastsByYear()
    {
        forecastsByYear = forecasts
            .GroupBy(f => f.Year)
            .ToDictionary(g => g.Key, g => g.ToList());

        totalPages = forecastsByYear.Count;
    }

    public void CalculateStartingCashStack()
    {
        startingCashStack = 0;
        if (SelectedValues != null)
        {
            foreach (var accnt in Accnts)
            {
                if (SelectedValues.Contains(accnt.Id.ToString()))
                {
                    startingCashStack += accnt.Amount;
                }
            }
        }
    }

    public void CalculateSavingsPerMonth()
    {
        savingsPerMonth = 0;
        foreach (var savings in roadMaps)
        {
            savingsPerMonth += savings.RoadMapSavingAmount;
        }
    }

    public void Calculate()
    {
        if (totalMonthsDisplay == null)
        {
            totalMonths = 0;
        }
        else { totalMonths = Convert.ToInt32(totalMonthsDisplay); }
        if (totalYearsDisplay == null)
        {
            totalYears = 0;
        }
        else { totalYears = Convert.ToInt32(totalYearsDisplay); }
        forecasts.Clear();
        DateTime today = DateTime.Today;
        DateTime startDate = new DateTime(today.Year, today.Month, 1);
        DateTime endDate = new DateTime(today.Year, today.Month, 1).AddYears(totalYears).AddMonths(totalMonths);
        if (!notUseingStartingCashStack)
        {
            CalculateStartingCashStack();
        }
        CalculateSavingsPerMonth();
        double startingCash = notUseingStartingCashStack ? 0 : startingCashStack;
        while (startDate != endDate)
        {
            int month = startDate.Month;
            int year = startDate.Year;
            startingCash += savingsPerMonth;
            Forecasts forecast = new Forecasts()
                {
                    Month = _dbService.MonthAbbreviations[month - 1],
                    Year = year,
                    cashStack = startingCash,
                    Income = savingsPerMonth,
                    ExtraIncome = 0,
                    RecurringExtraIncome = false,
                    Total = startingCash,
                    ForcastName = forcastName,
                };
            forecasts.Add(forecast);
            startDate = startDate.AddMonths(1);
        }
        isLoadedForecast = false;
        GroupForecastsByYear();
        CheckIfButtonsActive();
        CheckSaveButtonActivation();
    }

    public async void SaveForecasts()
    {
        if (forecasts != null && forecasts.Count > 0)
        {
            foreach (var f in forecasts)
            {
                f.ForcastName = forcastName;
            }

            if (isLoadedForecast)
            {
                await _dbService.RemoveForecasts(forcastName);
            }

            await _dbService.AddForecasts(forecasts);
            savedForecastNames = await Task.Run(() => _dbService.GetSavedForecastNames());
            isLoadedForecast = true;
            StateHasChanged();
        }
    }

    private async Task LoadSavedForecast()
    {
        if (string.IsNullOrWhiteSpace(selectedSavedForecastName)) return;

        forecasts = await Task.Run(() => _dbService.GetForecastsByName(selectedSavedForecastName));
        forcastName = selectedSavedForecastName;
        isLoadedForecast = true;
        currentPage = 0;
        GroupForecastsByYear();
        CheckIfButtonsActive();
        CheckSaveButtonActivation();
        StateHasChanged();
    }

    private async Task DeleteSavedForecast()
    {
        if (string.IsNullOrWhiteSpace(selectedSavedForecastName)) return;

        await _dbService.RemoveForecasts(selectedSavedForecastName);
        savedForecastNames = await Task.Run(() => _dbService.GetSavedForecastNames());

        if (forcastName == selectedSavedForecastName)
        {
            NewForecast();
        }

        selectedSavedForecastName = null;
        StateHasChanged();
    }

    private void NewForecast()
    {
        forecasts.Clear();
        forcastName = "";
        isLoadedForecast = false;
        currentPage = 0;
        GroupForecastsByYear();
        CheckIfButtonsActive();
        CheckSaveButtonActivation();
    }

    private void HandleForecastNameChanged(string value)
    {
        forcastName = value ?? "";
        CheckSaveButtonActivation();
    }

    public void CheckSaveButtonActivation()
    {
        if (forecasts.Count > 0 && forcastName.Length > 0)
        {
            isSaveDisabled = false;
        }
        else
        {
            isSaveDisabled = true;
        }
    }
    // End of Forecast Manipulation
}