@inherits LayoutComponentBase
@using Financial_ForeCast.Services
@using Microsoft.AspNetCore.Components.Routing
@inject DbServiceProvider _dbProvider
@inject ConnectivityService _connectivity
@inject BackupSyncService _backupSync
@inject ThemeService _themeService
@inject ISnackbar Snackbar
@inject NavigationManager _nav
@implements IDisposable
@* Required *@
<MudThemeProvider Theme="@_themeService.Current.Theme" IsDarkMode="@_themeService.Current.IsDark" />
<MudPopoverProvider />

@* Needed for dialogs *@
<MudDialogProvider />

@* Needed for snackbars *@
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Fixed="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        @if (!_isHomePage)
        {
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Inherit" OnClick="@GoBack" />
        }
        <MudText Typo="Typo.subtitle1" Class="ml-2" Style="font-weight:600;">Budget Mate</MudText>
        @if (_dbProvider.IsOfflineMode)
        {
            <MudChip T="string" Color="Color.Warning" Size="Size.Small" Class="ml-2">Offline</MudChip>
        }
        else if (_hasRemoteConfig)
        {
            <MudChip T="string" Color="Color.Success" Size="Size.Small" Class="ml-2">Online</MudChip>
        }
        <MudSpacer />
        <MudMenu Icon="@Icons.Material.Filled.Palette" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
            @foreach (var theme in _themeService.AvailableThemes)
            {
                <MudMenuItem OnClick="@(() => ChangeTheme(theme.Name))">
                    <div class="d-flex align-center gap-2">
                        @if (theme.Name == _themeService.Current.Name)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Style="visibility:hidden;" />
                        }
                        <MudText>@theme.Name</MudText>
                    </div>
                </MudMenuItem>
            }
        </MudMenu>
    </MudAppBar>
    <MudDrawer @bind-Open="@_drawerOpen" ClipMode="DrawerClipMode.Never" Elevation="2">
        <NavMenu />
    </MudDrawer>
    <MudMainContent Class="mt-0">
        @Body
    </MudMainContent>
</MudLayout>


@code {
    bool _drawerOpen = false;
    bool _hasRemoteConfig = false;
    bool _isHomePage = true;

    protected override void OnInitialized()
    {
        _hasRemoteConfig = _connectivity.HasRemoteConfig;
        _dbProvider.OnModeChanged += HandleModeChanged;
        _backupSync.OnBackupStatusChanged += HandleBackupStatus;
        _themeService.OnThemeChanged += HandleThemeChanged;
        _nav.LocationChanged += HandleLocationChanged;
        UpdateIsHomePage();
    }

    private void HandleModeChanged(bool isOnline)
    {
        InvokeAsync(() =>
        {
            _hasRemoteConfig = _connectivity.HasRemoteConfig;
            if (isOnline)
            {
                var message = "Back Online: Connection to the remote database has been restored.";
                if (BackupSyncService.IsPushOnReconnect())
                    message += " Local data has been pushed to the server.";
                Snackbar.Add(message, Severity.Success);
            }
            else
            {
                Snackbar.Add("Offline Mode: The remote database is unreachable. You are now using local data.", Severity.Warning);
            }
            StateHasChanged();
        });
    }

    private void HandleBackupStatus(string status)
    {
        InvokeAsync(() =>
        {
            Snackbar.Add(status, Severity.Info);
        });
    }

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void GoBack()
    {
        _nav.NavigateTo("/");
    }

    private void HandleLocationChanged(object sender, LocationChangedEventArgs e)
    {
        InvokeAsync(() =>
        {
            UpdateIsHomePage();
            StateHasChanged();
        });
    }

    private void UpdateIsHomePage()
    {
        var relativePath = _nav.ToBaseRelativePath(_nav.Uri);
        _isHomePage = string.IsNullOrEmpty(relativePath) || relativePath == "/";
    }

    private void ChangeTheme(string name)
    {
        _themeService.SetTheme(name);
    }

    private void HandleThemeChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _dbProvider.OnModeChanged -= HandleModeChanged;
        _backupSync.OnBackupStatusChanged -= HandleBackupStatus;
        _themeService.OnThemeChanged -= HandleThemeChanged;
        _nav.LocationChanged -= HandleLocationChanged;
    }
}
